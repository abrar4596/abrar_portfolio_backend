# Port for the Express server to run on
PORT=5000

# MongoDB Connection String (e.g., local or MongoDB Atlas)
# Local: mongodb://localhost:27017/portfolio
# Atlas: mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/portfolio?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/portfolio

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:3000
